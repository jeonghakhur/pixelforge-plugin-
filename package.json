{
  "name": "pixelforge-plugin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "dev": "node build.mjs --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@figma/plugin-typings": "^1.100.0",
    "@types/jszip": "^3.4.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  },
  "lint-staged": {
    "src/code.ts": ["eslint --fix", "prettier --write"],
    "src/**/*.tsx": ["eslint --fix", "prettier --write"],
    "src/ui.js": ["eslint --fix", "prettier --write"],
    "src/converters/*.js": ["eslint --fix", "prettier --write"]
  }
}
